generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  user_id    String   @unique
  username   String?
  first_name String?
  last_name  String?
  tests      Json     @default("[]")
  balance    Int      @default(0)
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
}


enum TestType{
  FREE
  PREMIUM
}

model Test {
  id                  Int           @id @default(autoincrement())
  name                String        @unique
  status              Status        @default(ACTIVE)
  responce            String[]
  students            Json          @default("[]")
  rash                Json          @default("{}")
  createdByUserId     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  type                TestType      @default(FREE)
  price               Int?
}

